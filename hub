    <!-- Footer -->
    <footer class="bg-slate-900 text-gray-400 py-12">
        <div class="max-w-7xl mx-auto px-6 text-center">
            <p>&copy; 2026 payxrpl.io • Open Source Hub for XRPL × DTCC</p>
            <p class="text-xs mt-4">Not affiliated with Ripple, DTCC, or Chainlink. For educational & development purposes.</p>
        </div>
    </footer>

    <script>
        // Tailwind script already loaded
        document.getElementById('margin').addEventListener('input', function() {
            document.getElementById('marginValue').textContent = this.value + '%';
        });

        function runSimulation() {
            const value = parseFloat(document.getElementById('assetValue').value) || 1000000;
            const margin = parseFloat(document.getElementById('margin').value);
            const savings = Math.round(value * (margin/100) * 0.35); // 35% efficiency gain example

            const result = document.getElementById('result');
            document.getElementById('savings').textContent = '$' + savings.toLocaleString();
            result.classList.remove('hidden');
        }
    </script>
</body>
</html>
