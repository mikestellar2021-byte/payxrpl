    <div class="bg-white dark:bg-slate-900 py-8 border-b">
        <div class="max-w-6xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
            <div>
                <div class="text-3xl font-bold text-blue-600">July 2026</div>
