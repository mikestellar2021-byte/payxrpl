    <!-- Live Demo / Tool -->
    <section class="py-20 bg-gray-100 dark:bg-slate-950">
        <div class="max-w-4xl mx-auto px-6">
            <h2 class="text-4xl font-bold text-center mb-4">Try the Collateral Simulator</h2>
            <p class="text-center text-gray-600 dark:text-gray-400 mb-10">See how much capital you can free up using XRPL + DTCC flows</p>

            <div class="bg-white dark:bg-slate-900 rounded-3xl p-10 shadow-xl">
                <div class="grid md:grid-cols-2 gap-10">
                    <div>
                        <label class="block text-sm font-medium mb-2">DTCC Asset Value (USD)</label>
                        <input id="assetValue" type="number" value="1000000" class="w-full p-4 rounded-2xl border dark:bg-slate-800 text-2xl font-mono">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Margin Requirement</label>
                        <input id="margin" type="range" min="5" max="50" value="15" class="w-full accent-blue-600">
                        <div class="text-center text-3xl font-bold mt-2" id="marginValue">15%</div>
                    </div>
                </div>

                <button onclick="runSimulation()" class="mt-10 w-full bg-blue-600 hover:bg-blue-700 text-white py-6 rounded-3xl text-xl font-semibold transition">
                    Simulate XRPL Rebalancing
                </button>

                <div id="result" class="mt-8 hidden bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-2xl p-8 text-center">
                    <div class="text-4xl font-bold text-green-600" id="savings"></div>
                    <p class="mt-3 text-green-700 dark:text-green-400">Capital freed up with XRPL 3-5s settlement</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-blue-700 text-white">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="text-4xl font-bold mb-6">Ready to build institutional-grade XRPL payments?</h2>
            <p class="text-xl mb-10">Get custom integrations, private simulators, or white-label tools for your business.</p>
            <a href="mailto:your@email.com" class="inline-block bg-white text-blue-700 px-10 py-5 rounded-3xl font-semibold text-lg hover:bg-blue-50">
                Contact for Freelance / Custom Work
            </a>
        </div>
