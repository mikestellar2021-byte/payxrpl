    <!-- Guides Section -->
    <section id="guides" class="py-20 bg-white dark:bg-slate-900">
        <div class="max-w-6xl mx-auto px-6">
            <h2 class="text-4xl font-bold text-center mb-4">Practical Guides</h2>
            <p class="text-center text-gray-600 dark:text-gray-400 mb-12">Everything you need to bridge XRPL payments with institutional flows</p>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Guide 1 -->
                <div class="bg-gray-50 dark:bg-slate-800 rounded-3xl p-8 card-hover">
                    <div class="text-blue-600 mb-4"><i class="fa-solid fa-rocket text-3xl"></i></div>
                    <h3 class="text-2xl font-semibold mb-3">Getting Started with XRPL + DTCC</h3>
