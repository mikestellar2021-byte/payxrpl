                <div class="bg-gray-50 dark:bg-slate-800 rounded-3xl p-8 card-hover">
                    <div class="text-blue-600 mb-4"><i class="fa-solid fa-arrows-rotate text-3xl"></i></div>
                    <h3 class="text-2xl font-semibold mb-3">Collateral Optimization</h3>
                    <p class="text-gray-600 dark:text-gray-400 mb-6">Simulate margin calls and rebalance between DTCC-cleared assets and XRPL AMM.</p>
                    <a href="#" class="text-blue-600 font-medium flex items-center gap-2">Read Guide →</a>
                </div>

                <!-- Guide 3 -->
                <div class="bg-gray-50 dark:bg-slate-800 rounded-3xl p-8 card-hover">
                    <div class="text-blue-600 mb-4"><i class="fa-solid fa-link text-3xl"></i></div>
